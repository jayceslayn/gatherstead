{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.44.1.10279",
      "templateHash": "86300322442335050"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "metadata": {
        "description": "The Azure region for observability resources."
      }
    },
    "workload": {
      "type": "string",
      "metadata": {
        "description": "Workload token used in CAF resource names."
      }
    },
    "environment": {
      "type": "string",
      "metadata": {
        "description": "Environment token used in CAF resource names."
      }
    },
    "locationAbbreviation": {
      "type": "string",
      "metadata": {
        "description": "Region abbreviation used in CAF resource names."
      }
    },
    "logRetentionDays": {
      "type": "int",
      "defaultValue": 30,
      "minValue": 30,
      "maxValue": 730,
      "metadata": {
        "description": "Number of days to retain logs in the workspace. Use 30 for dev, 90 for prod."
      }
    },
    "oncallEmail": {
      "type": "string",
      "metadata": {
        "description": "Email address for oncall alert notifications."
      }
    },
    "appManagedIdentityPrincipalId": {
      "type": "string",
      "metadata": {
        "description": "Principal ID of the app managed identity (granted Monitoring Metrics Publisher on App Insights)."
      }
    },
    "deployDemo": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Whether to provision a separate App Insights component for the demo static site."
      }
    }
  },
  "variables": {
    "workspaceName": "[format('log-{0}-{1}-{2}', parameters('workload'), parameters('environment'), parameters('locationAbbreviation'))]",
    "appInsightsName": "[format('appi-{0}-{1}-{2}', parameters('workload'), parameters('environment'), parameters('locationAbbreviation'))]",
    "demoAppInsightsName": "[format('appi-{0}-demo-{1}-{2}', parameters('workload'), parameters('environment'), parameters('locationAbbreviation'))]",
    "monitoringMetricsPublisherRoleId": "3913510d-42f4-4e42-8a64-420c390055eb"
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[variables('workspaceName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": "[parameters('logRetentionDays')]",
        "features": {
          "enableLogAccessUsingOnlyResourcePermissions": true
        }
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[variables('appInsightsName')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('workspaceName'))]",
        "IngestionMode": "LogAnalytics",
        "publicNetworkAccessForIngestion": "Enabled",
        "publicNetworkAccessForQuery": "Enabled"
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('workspaceName'))]"
      ]
    },
    {
      "condition": "[parameters('deployDemo')]",
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[variables('demoAppInsightsName')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('workspaceName'))]",
        "IngestionMode": "LogAnalytics",
        "publicNetworkAccessForIngestion": "Enabled",
        "publicNetworkAccessForQuery": "Enabled"
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('workspaceName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.Insights/components', variables('appInsightsName'))]",
      "name": "[guid(resourceId('Microsoft.Insights/components', variables('appInsightsName')), parameters('appManagedIdentityPrincipalId'), variables('monitoringMetricsPublisherRoleId'))]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('monitoringMetricsPublisherRoleId'))]",
        "principalId": "[parameters('appManagedIdentityPrincipalId')]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/components', variables('appInsightsName'))]"
      ]
    },
    {
      "type": "Microsoft.Insights/actionGroups",
      "apiVersion": "2023-01-01",
      "name": "[format('ag-{0}-oncall-{1}-{2}', parameters('workload'), parameters('environment'), parameters('locationAbbreviation'))]",
      "location": "global",
      "properties": {
        "groupShortName": "gat-oncall",
        "enabled": true,
        "emailReceivers": [
          {
            "name": "oncall-email",
            "emailAddress": "[parameters('oncallEmail')]",
            "useCommonAlertSchema": true
          }
        ]
      }
    },
    {
      "type": "Microsoft.Insights/metricAlerts",
      "apiVersion": "2018-03-01",
      "name": "[format('alert-{0}-failed-requests-{1}-{2}', parameters('workload'), parameters('environment'), parameters('locationAbbreviation'))]",
      "location": "global",
      "properties": {
        "description": "API failed request count exceeded threshold — investigate recent deployments or errors.",
        "severity": 2,
        "enabled": true,
        "scopes": [
          "[resourceId('Microsoft.Insights/components', variables('appInsightsName'))]"
        ],
        "evaluationFrequency": "PT1M",
        "windowSize": "PT5M",
        "criteria": {
          "odata.type": "Microsoft.Azure.Monitor.SingleResourceMultipleMetricCriteria",
          "allOf": [
            {
              "name": "FailedRequests",
              "metricName": "requests/failed",
              "metricNamespace": "microsoft.insights/components",
              "operator": "GreaterThan",
              "threshold": 5,
              "timeAggregation": "Count",
              "criterionType": "StaticThresholdCriterion"
            }
          ]
        },
        "actions": [
          {
            "actionGroupId": "[resourceId('Microsoft.Insights/actionGroups', format('ag-{0}-oncall-{1}-{2}', parameters('workload'), parameters('environment'), parameters('locationAbbreviation')))]"
          }
        ],
        "autoMitigate": true
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/actionGroups', format('ag-{0}-oncall-{1}-{2}', parameters('workload'), parameters('environment'), parameters('locationAbbreviation')))]",
        "[resourceId('Microsoft.Insights/components', variables('appInsightsName'))]"
      ]
    },
    {
      "type": "Microsoft.Insights/metricAlerts",
      "apiVersion": "2018-03-01",
      "name": "[format('alert-{0}-dependency-failures-{1}-{2}', parameters('workload'), parameters('environment'), parameters('locationAbbreviation'))]",
      "location": "global",
      "properties": {
        "description": "Dependency failure count (SQL, Key Vault, etc.) exceeded threshold — may indicate downstream outage.",
        "severity": 1,
        "enabled": true,
        "scopes": [
          "[resourceId('Microsoft.Insights/components', variables('appInsightsName'))]"
        ],
        "evaluationFrequency": "PT1M",
        "windowSize": "PT5M",
        "criteria": {
          "odata.type": "Microsoft.Azure.Monitor.SingleResourceMultipleMetricCriteria",
          "allOf": [
            {
              "name": "FailedDependencies",
              "metricName": "dependencies/failed",
              "metricNamespace": "microsoft.insights/components",
              "operator": "GreaterThan",
              "threshold": 3,
              "timeAggregation": "Count",
              "criterionType": "StaticThresholdCriterion"
            }
          ]
        },
        "actions": [
          {
            "actionGroupId": "[resourceId('Microsoft.Insights/actionGroups', format('ag-{0}-oncall-{1}-{2}', parameters('workload'), parameters('environment'), parameters('locationAbbreviation')))]"
          }
        ],
        "autoMitigate": true
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/actionGroups', format('ag-{0}-oncall-{1}-{2}', parameters('workload'), parameters('environment'), parameters('locationAbbreviation')))]",
        "[resourceId('Microsoft.Insights/components', variables('appInsightsName'))]"
      ]
    }
  ],
  "outputs": {
    "workspaceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('workspaceName'))]"
    },
    "appInsightsConnectionString": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').ConnectionString]"
    },
    "appInsightsId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Insights/components', variables('appInsightsName'))]"
    },
    "actionGroupId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Insights/actionGroups', format('ag-{0}-oncall-{1}-{2}', parameters('workload'), parameters('environment'), parameters('locationAbbreviation')))]"
    },
    "demoAppInsightsConnectionString": {
      "type": "string",
      "value": "[if(parameters('deployDemo'), reference(resourceId('Microsoft.Insights/components', variables('demoAppInsightsName')), '2020-02-02').ConnectionString, '')]"
    }
  }
}