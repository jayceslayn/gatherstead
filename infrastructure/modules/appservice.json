{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.44.1.10279",
      "templateHash": "17795029780854529743"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "metadata": {
        "description": "The Azure region where App Service resources will be created."
      }
    },
    "workload": {
      "type": "string",
      "metadata": {
        "description": "Workload token used in CAF resource names."
      }
    },
    "environment": {
      "type": "string",
      "metadata": {
        "description": "Environment token used in CAF resource names."
      }
    },
    "locationAbbreviation": {
      "type": "string",
      "metadata": {
        "description": "Region abbreviation used in CAF resource names."
      }
    },
    "resourceToken": {
      "type": "string",
      "metadata": {
        "description": "Short deterministic suffix ensuring the globally-unique App Service names are free."
      }
    },
    "appServicePlanSku": {
      "type": "string",
      "defaultValue": "F1",
      "allowedValues": [
        "F1",
        "B1",
        "B2",
        "B3",
        "S1",
        "S2",
        "S3",
        "P1v3",
        "P2v3",
        "P3v3"
      ],
      "metadata": {
        "description": "The App Service Plan SKU. Use F1 for dev (free) or B1 for prod (basic, always-on)."
      }
    },
    "appManagedIdentityId": {
      "type": "string",
      "metadata": {
        "description": "Full resource ID of the user-assigned managed identity to attach to the API app."
      }
    },
    "appManagedIdentityClientId": {
      "type": "string",
      "metadata": {
        "description": "Client ID of the managed identity — set as AZURE_CLIENT_ID so DefaultAzureCredential selects the correct identity."
      }
    },
    "sqlServerFqdn": {
      "type": "string",
      "metadata": {
        "description": "Fully qualified domain name of the SQL server."
      }
    },
    "sqlDatabaseName": {
      "type": "string",
      "metadata": {
        "description": "Name of the SQL database."
      }
    },
    "keyVaultUri": {
      "type": "string",
      "metadata": {
        "description": "URI of the Key Vault instance."
      }
    },
    "workspaceId": {
      "type": "string",
      "metadata": {
        "description": "Resource ID of the Log Analytics workspace for diagnostic settings."
      }
    },
    "appInsightsConnectionString": {
      "type": "string",
      "metadata": {
        "description": "Application Insights connection string injected into both apps."
      }
    },
    "externalIdentityInstance": {
      "type": "string",
      "metadata": {
        "description": "External ID instance/authority host, e.g. https://your-tenant.ciamlogin.com."
      }
    },
    "externalIdentityDomain": {
      "type": "string",
      "metadata": {
        "description": "External ID domain, e.g. your-tenant.onmicrosoft.com."
      }
    },
    "externalIdentityClientId": {
      "type": "string",
      "metadata": {
        "description": "App registration (client) ID of the API — used as the JWT audience."
      }
    },
    "externalIdentitySignUpSignInPolicyId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "B2C sign-up/sign-in policy (user flow) ID. Empty for Entra External ID."
      }
    },
    "externalIdentityValidIssuer": {
      "type": "string",
      "metadata": {
        "description": "Expected token issuer, e.g. https://your-tenant.ciamlogin.com/<tenant-id>/v2.0/."
      }
    },
    "webManagedIdentityId": {
      "type": "string",
      "metadata": {
        "description": "Full resource ID of the dedicated web managed identity (used for Key Vault references)."
      }
    },
    "webExternalIdentityClientId": {
      "type": "string",
      "metadata": {
        "description": "App registration (client) ID of the Nuxt web app for the OIDC sign-in flow."
      }
    },
    "webExternalIdentityTenantName": {
      "type": "string",
      "metadata": {
        "description": "External ID tenant subdomain for the web app, e.g. gatherstead (→ gatherstead.ciamlogin.com)."
      }
    },
    "webExternalIdentityApiScope": {
      "type": "string",
      "metadata": {
        "description": "The API scope the web app requests so its access token is audienced for the API, e.g. api://<api-client-id>/access_as_user."
      }
    }
  },
  "variables": {
    "planName": "[format('asp-{0}-{1}-{2}', parameters('workload'), parameters('environment'), parameters('locationAbbreviation'))]",
    "apiAppName": "[format('app-{0}-api-{1}-{2}-{3}', parameters('workload'), parameters('environment'), parameters('locationAbbreviation'), parameters('resourceToken'))]",
    "webAppName": "[format('app-{0}-web-{1}-{2}-{3}', parameters('workload'), parameters('environment'), parameters('locationAbbreviation'), parameters('resourceToken'))]",
    "connectionString": "[format('Server=tcp:{0},1433;Database={1};Authentication=Active Directory Managed Identity;User Id={2};Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;Column Encryption Setting=Enabled;', parameters('sqlServerFqdn'), parameters('sqlDatabaseName'), parameters('appManagedIdentityClientId'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-12-01",
      "name": "[variables('planName')]",
      "location": "[parameters('location')]",
      "kind": "linux",
      "sku": {
        "name": "[parameters('appServicePlanSku')]"
      },
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[variables('apiAppName')]",
      "location": "[parameters('location')]",
      "kind": "app,linux",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', parameters('appManagedIdentityId'))]": {}
        }
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "DOTNETCORE|10.0",
          "alwaysOn": "[not(equals(parameters('appServicePlanSku'), 'F1'))]",
          "appSettings": [
            {
              "name": "AZURE_CLIENT_ID",
              "value": "[parameters('appManagedIdentityClientId')]"
            },
            {
              "name": "Authentication__KeyVault__VaultUrl",
              "value": "[parameters('keyVaultUri')]"
            },
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[parameters('appInsightsConnectionString')]"
            },
            {
              "name": "ApplicationInsightsAgent_EXTENSION_VERSION",
              "value": "~3"
            },
            {
              "name": "Cors__AllowedOrigins__0",
              "value": "[format('https://{0}.azurewebsites.net', variables('webAppName'))]"
            },
            {
              "name": "ExternalIdentity__Instance",
              "value": "[parameters('externalIdentityInstance')]"
            },
            {
              "name": "ExternalIdentity__Domain",
              "value": "[parameters('externalIdentityDomain')]"
            },
            {
              "name": "ExternalIdentity__ClientId",
              "value": "[parameters('externalIdentityClientId')]"
            },
            {
              "name": "ExternalIdentity__SignUpSignInPolicyId",
              "value": "[parameters('externalIdentitySignUpSignInPolicyId')]"
            },
            {
              "name": "ExternalIdentity__ValidIssuer",
              "value": "[parameters('externalIdentityValidIssuer')]"
            }
          ],
          "connectionStrings": [
            {
              "name": "Default",
              "connectionString": "[variables('connectionString')]",
              "type": "SQLAzure"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[variables('webAppName')]",
      "location": "[parameters('location')]",
      "kind": "app,linux",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', parameters('webManagedIdentityId'))]": {}
        }
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
        "httpsOnly": true,
        "keyVaultReferenceIdentity": "[parameters('webManagedIdentityId')]",
        "siteConfig": {
          "linuxFxVersion": "NODE|24-lts",
          "alwaysOn": "[not(equals(parameters('appServicePlanSku'), 'F1'))]",
          "appCommandLine": "node .output/server/index.mjs",
          "appSettings": [
            {
              "name": "NUXT_PUBLIC_API_BASE_URL",
              "value": "[format('https://{0}.azurewebsites.net', variables('apiAppName'))]"
            },
            {
              "name": "WEBSITE_RUN_FROM_PACKAGE",
              "value": "1"
            },
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[parameters('appInsightsConnectionString')]"
            },
            {
              "name": "ApplicationInsightsAgent_EXTENSION_VERSION",
              "value": "~3"
            },
            {
              "name": "NUXT_PUBLIC_APP_INSIGHTS_CONNECTION_STRING",
              "value": "[parameters('appInsightsConnectionString')]"
            },
            {
              "name": "NUXT_EXTERNAL_IDENTITY_CLIENT_ID",
              "value": "[parameters('webExternalIdentityClientId')]"
            },
            {
              "name": "NUXT_EXTERNAL_IDENTITY_TENANT_NAME",
              "value": "[parameters('webExternalIdentityTenantName')]"
            },
            {
              "name": "NUXT_EXTERNAL_IDENTITY_API_SCOPE",
              "value": "[parameters('webExternalIdentityApiScope')]"
            },
            {
              "name": "NUXT_SESSION_PASSWORD",
              "value": "[format('@Microsoft.KeyVault(SecretUri={0}secrets/nuxt-session-password/)', parameters('keyVaultUri'))]"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]"
      ]
    },
    {
      "type": "Microsoft.Insights/diagnosticSettings",
      "apiVersion": "2021-05-01-preview",
      "scope": "[resourceId('Microsoft.Web/sites', variables('apiAppName'))]",
      "name": "diag-api",
      "properties": {
        "workspaceId": "[parameters('workspaceId')]",
        "logs": [
          {
            "category": "AppServiceHTTPLogs",
            "enabled": true
          },
          {
            "category": "AppServiceConsoleLogs",
            "enabled": true
          },
          {
            "category": "AppServiceAppLogs",
            "enabled": true
          },
          {
            "category": "AppServiceAuditLogs",
            "enabled": true
          },
          {
            "category": "AppServiceIPSecAuditLogs",
            "enabled": true
          },
          {
            "category": "AppServicePlatformLogs",
            "enabled": true
          }
        ],
        "metrics": [
          {
            "category": "AllMetrics",
            "enabled": true
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('apiAppName'))]"
      ]
    },
    {
      "type": "Microsoft.Insights/diagnosticSettings",
      "apiVersion": "2021-05-01-preview",
      "scope": "[resourceId('Microsoft.Web/sites', variables('webAppName'))]",
      "name": "diag-web",
      "properties": {
        "workspaceId": "[parameters('workspaceId')]",
        "logs": [
          {
            "category": "AppServiceHTTPLogs",
            "enabled": true
          },
          {
            "category": "AppServiceConsoleLogs",
            "enabled": true
          },
          {
            "category": "AppServiceAppLogs",
            "enabled": true
          },
          {
            "category": "AppServiceAuditLogs",
            "enabled": true
          },
          {
            "category": "AppServiceIPSecAuditLogs",
            "enabled": true
          },
          {
            "category": "AppServicePlatformLogs",
            "enabled": true
          }
        ],
        "metrics": [
          {
            "category": "AllMetrics",
            "enabled": true
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('webAppName'))]"
      ]
    }
  ],
  "outputs": {
    "apiAppName": {
      "type": "string",
      "value": "[variables('apiAppName')]"
    },
    "apiAppUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites', variables('apiAppName')), '2023-12-01').defaultHostName)]"
    },
    "webAppName": {
      "type": "string",
      "value": "[variables('webAppName')]"
    },
    "webAppUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites', variables('webAppName')), '2023-12-01').defaultHostName)]"
    }
  }
}