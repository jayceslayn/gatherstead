using '../main.bicep'

param location = '<region>'
param resourceGroupName = 'rg-gat-prod-<region-abbreviation>'

// CAF naming tokens — resources are named <type>-${workload}-${environment}-${locationAbbreviation}
// (e.g. kv-gat-prod-wus2), with a short hash suffix on the globally-unique ones. Set the region
// abbreviation to match `location`, e.g. wus2 for westus2, eus for eastus.
param environment = 'prod'
param locationAbbreviation = '<region-abbreviation>'

// Object ID of the Entra ID group designated as SQL administrator in production.
// Get with: az ad group show --group "<group-name>" --query id -o tsv
param sqlEntraAdminObjectId = '<prod-admin-group-object-id>'
param sqlEntraAdminLogin = '<prod-admin-group-name>'

// Object ID of the service principal used by CI/CD to run deployments.
// Get with: az ad sp show --id "<app-id>" --query id -o tsv
param deployerObjectId = '<cicd-service-principal-object-id>'

// Basic tier: 1 dedicated core, 1.75 GB RAM, always-on, custom domains (~$13/month/plan).
// Scale up to B2/B3/P1v3 as traffic grows.
param appServicePlanSku = 'B1'

// 90 days matches the App Insights default and gives enough runway for incident investigation.
param logRetentionDays = 90

// Distribution list or PagerDuty email for production oncall alerts.
param oncallEmail = '<oncall-distribution-list-or-pagerduty-email>'

// External identity provider (Microsoft Entra External ID / Azure AD B2C) — validates the API's
// JWT bearer tokens. All non-secret (bearer validation uses the IdP's published OIDC signing keys).
//   - Entra External ID: leave SignUpSignInPolicyId empty (no user-flow policy segment).
//   - Azure AD B2C:      set Instance to https://<tenant>.b2clogin.com and SignUpSignInPolicyId to
//                        the user-flow id (e.g. B2C_1A_SIGNUP_SIGNIN).
param externalIdentityInstance = 'https://<tenant-subdomain>.ciamlogin.com'
param externalIdentityDomain = '<tenant-subdomain>.onmicrosoft.com'
param externalIdentityClientId = '<api-app-registration-client-id>'
param externalIdentitySignUpSignInPolicyId = ''
param externalIdentityValidIssuer = 'https://<tenant-subdomain>.ciamlogin.com/<tenant-id>/v2.0/'

// Nuxt web app sign-in (Entra External ID, server-side OIDC + PKCE). All non-secret — PKCE replaces
// the client secret, and NUXT_SESSION_PASSWORD is a Key Vault secret (create out-of-band), not a param.
param webExternalIdentityClientId = '<web-app-registration-client-id>'
param webExternalIdentityTenantName = '<tenant-subdomain>'
param webExternalIdentityApiScope = 'api://<api-app-registration-client-id>/access_as_user'

// Delete the Entra directory account during account erasure. Keep false until the API managed identity
// has been granted the Graph User.DeleteRestricted.All app role (see DEPLOYMENT.md → "Enable directory-
// account deletion"). When false, app data still erases fully; the directory account is left for manual removal.
param externalIdentityDirectoryManagementEnabled = false

// Public legal identity for /contact, /terms and /privacy (browser-exposed, non-secret). Empty = neutral
// fallbacks. Provider = the party users contract with (your legal name, or a registered entity once formed);
// jurisdiction = the governing-law US state. Have the drafted Terms/Privacy reviewed by counsel before launch.
param webContactEmail = ''
param webLegalProvider = ''
param webLegalJurisdiction = ''

// Provision the public demo static web app (+ its appi-gat-demo-* App Insights) in this resource
// group, and grant the CI identity the role to fetch its deployment token. Set false to skip it.
param deployDemo = true
