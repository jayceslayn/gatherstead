# nuxt-auth-utils session encryption key — minimum 32 characters, random string
NUXT_SESSION_PASSWORD=change-me-to-a-random-string-of-at-least-32-characters

# Azure AD B2C / CIAM — used for server-side OIDC flow
NUXT_EXTERNAL_IDENTITY_CLIENT_ID=00000000-0000-0000-0000-000000000000
NUXT_EXTERNAL_IDENTITY_CLIENT_SECRET=your-client-secret
NUXT_EXTERNAL_IDENTITY_TENANT_NAME=your-tenant
NUXT_EXTERNAL_IDENTITY_POLICY=B2C_1A_SIGNUP_SIGNIN

# Public runtime config — safe to expose to the browser
NUXT_PUBLIC_API_BASE_URL=http://localhost:5000
NUXT_PUBLIC_DEMO_MODE=false
NUXT_PUBLIC_GITHUB_URL=
NUXT_PUBLIC_DOCS_URL=
# URL of the live app — shown as a CTA in the demo mode modal
NUXT_PUBLIC_LIVE_URL=
# URL of the demo site — shown as a "Try the Demo" button on the live landing page
NUXT_PUBLIC_DEMO_URL=
